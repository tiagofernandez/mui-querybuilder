{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "declarationDir": "./dist",
        "sourceMap": true,
        "outDir": "./dist",
        "lib": ["ES2022", "DOM", "DOM.Iterable"]
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist", "tests", "stories"]
}
